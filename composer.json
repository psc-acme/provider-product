{
    "name": "psc-acme/provider-product",
    "description": "Package provider-product for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ProviderProduct\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0",
        "symfony/serializer": "^7.0",
        "symfony/lock": "^7.0",
        "laravel/framework": "^11.0",
        "brick/date-time": "^0.7.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}